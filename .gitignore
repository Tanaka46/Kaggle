*.py[cod]
*.egg-info/
.ipynb_checkpoints/
.venv/
venv/
env/

# --- Jupyter ---
*.ipynb_checkpoints

# --- OS / Editor ---
.DS_Store
Thumbs.db
.vscode/
.idea/

